# Sample environment file. Copy to .env and fill in real values.
# In production, the .env file lives on the server and is never committed.

# Core
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=UTC

# Database (production only). django-environ parses a URL into ENGINE/NAME/etc.
# Example: postgres://user:password@127.0.0.1:5432/payroll
DATABASE_URL=postgres://payroll:payroll@127.0.0.1:5432/payroll

# HTTPS hardening (production only). Set to False during initial bring-up
# before TLS is configured, then flip on.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
